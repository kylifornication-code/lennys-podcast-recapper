---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<header class="site-header">
  <div class="header-inner">
    <a href={base} class="site-title">Lenny's Podcast Recapper</a>
    <div class="header-actions">
      <nav class="header-nav">
      <a href={base} class="active" data-nav="all">All Episodes</a>
      </nav>
      <a
        href="https://github.com/kylifornication-code/lennys-podcast-recapper"
        target="_blank"
        rel="noopener noreferrer"
        class="header-repo-link"
        aria-label="View source on GitHub"
        title="View source on GitHub"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M12 2C6.48 2 2 6.58 2 12.24c0 4.53 2.87 8.36 6.84 9.72.5.1.68-.22.68-.5 0-.24-.01-1.05-.01-1.91-2.78.62-3.37-1.22-3.37-1.22-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.35 1.12 2.92.86.09-.67.35-1.12.63-1.38-2.22-.26-4.55-1.14-4.55-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.35 9.35 0 0 1 12 7.1c.85 0 1.71.12 2.51.35 1.91-1.34 2.75-1.05 2.75-1.05.54 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.95-2.33 4.81-4.56 5.07.36.32.68.95.68 1.91 0 1.38-.01 2.5-.01 2.84 0 .28.18.61.69.5A10.24 10.24 0 0 0 22 12.24C22 6.58 17.52 2 12 2Z"
          ></path>
        </svg>
        <span class="sr-only">View source on GitHub</span>
      </a>
    </div>
  </div>
</header>
