---
interface Props {
  slug: string;
  guest: string;
  title: string;
  video_id: string;
  publish_date: string;
  description: string;
  duration: string;
  view_count: number;
  keywords: string[];
}

const { slug, guest, title, video_id, publish_date, description, duration, view_count, keywords } = Astro.props;
const base = import.meta.env.BASE_URL;
const episodeUrl = `${base}episode/${slug}/`;
const thumbUrl = video_id ? `https://img.youtube.com/vi/${video_id}/mqdefault.jpg` : '';
const displayTitle = title || `Episode with ${guest}`;
const shortDesc = description ? description.slice(0, 160) : '';
const formattedDate = publish_date
  ? new Date(publish_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
  : '';
const formattedViews = view_count ? view_count.toLocaleString('en-US') : '';
---

<a href={episodeUrl} class="card" data-slug={slug} data-keywords={JSON.stringify(keywords)}>
  {thumbUrl ? (
    <img class="card-thumbnail" src={thumbUrl} alt={displayTitle} loading="lazy" />
  ) : (
    <div class="card-thumbnail" style="display:flex;align-items:center;justify-content:center;font-size:1.5rem;color:var(--color-text-muted);">
      🎙
    </div>
  )}
  <div class="card-body">
    <div class="card-guest">{guest}</div>
    <div class="card-title">{displayTitle}</div>
    {shortDesc && <div class="card-description">{shortDesc}</div>}
    <div class="card-meta">
      {formattedDate && (
        <span class="card-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          {formattedDate}
        </span>
      )}
      {duration && (
        <span class="card-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          {duration}
        </span>
      )}
      {formattedViews && (
        <span class="card-meta-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          {formattedViews}
        </span>
      )}
    </div>
    {keywords.length > 0 && (
      <div class="card-keywords">
        {keywords.slice(0, 4).map((kw) => (
          <span class="card-keyword">{kw}</span>
        ))}
      </div>
    )}
  </div>
</a>
